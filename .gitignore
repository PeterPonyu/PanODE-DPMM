# -- Full-catalogue experiment runs (entirely regenerable) --
experiments/results/ablation_dpmm_full/
experiments/results/ablation_topic_full/
experiments/results/full_comparison_all/
experiments/results/full_vs_external_all/
experiments/results/external_full/
experiments/results/mixed/
experiments/results/external/
# -- Per-series bulk data (keep only figures/) --
experiments/results/*/ablation/tables/
experiments/results/*/ablation/series/
experiments/results/*/ablation/cache/
experiments/results/*/ablation/latents/
experiments/results/*/ablation/figures/training_curves/
